{
  "cds_version": "1.0",
  "name": "ccplugin-code-quality",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/run-audit",
        "/run-refine",
        "/run-index"
      ]
    },
    {
      "type": "auto_trigger",
      "keywords": [
        "audit",
        "refine",
        "index",
        "code quality"
      ],
      "confirm": false,
      "cooldown": 0
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "file_generation",
      "path": ".claude/ config updates"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "jq"
      ],
      "required_secrets": [],
      "required_mcp": []
    }
  },
  "error_handling": {
    "retry_network": false,
    "max_retries": 0
  }
}
